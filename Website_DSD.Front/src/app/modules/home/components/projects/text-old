  <!-- ===== BODY ===== -->
  <div class="pd-body">
    <div class="container">
      <div class="pd-body-grid">

        <!-- ── Main Column ── -->
        <div class="pd-main-col">
          <div class="pd-card">

            <!-- ══════════════════════════
                 TAB BUTTONS
            ══════════════════════════ -->
            <div class="pd-tabs">
                 <button class="pd-tab"
                [class.active]="activeTab === 'howItWorks'"
                (click)="setTab('howItWorks')">
                <i class="fa-regular fa-circle-question"></i>
                {{ 'PROJECTS.HOW_IT_WORKS' | translate }}
              </button>

              <button class="pd-tab"
                [class.active]="activeTab === 'features'"
                (click)="activeTab = 'features'">
                <i class="fa-regular fa-star"></i>
                {{ 'PROJECTS.FEATURES' | translate }}
              </button>

              <button class="pd-tab"
                [class.active]="activeTab === 'gallery'"
                (click)="activeTab = 'gallery'">
                <i class="fa-regular fa-images"></i>
                {{ 'PROJECTS.GALLERY' | translate }}
              </button>

              <button class="pd-tab"
                *ngIf="project.video"
                [class.active]="activeTab === 'video'"
                (click)="activeTab = 'video'">
                <i class="fa-regular fa-circle-play"></i>
                {{ 'PROJECTS.VIDEO' | translate }}
              </button>

           

            </div>
            <!-- ══ END TAB BUTTONS ══ -->

            <!-- ══════════════════════════
                 TAB: Features
            ══════════════════════════ -->
            <div class="tab-content" *ngIf="activeTab === 'features'">
              <div class="features-grid">
                <div class="feature-item" *ngFor="let feature of project.features">
                  <div class="feature-icon-wrap" [style.background]="hexToRgba(project.color, 0.1)">
                    <i class="fa-regular fa-check" [style.color]="project.color"></i>
                  </div>
                  <div class="feature-text">
                    {{ (translate.currentLang === 'ar' ? feature.ar : feature.en) }}
                  </div>
                </div>
              </div>
            </div>

            <!-- ══════════════════════════
                 TAB: Gallery
            ══════════════════════════ -->
            <div class="tab-content" *ngIf="activeTab === 'gallery'">
              <div class="gallery-grid">
                <div class="gallery-item" *ngFor="let img of project.images">
                  <img [src]="img" [alt]="project.title" loading="lazy">
                  <div class="gallery-overlay">
                    <i class="fa-regular fa-magnifying-glass-plus"></i>
                  </div>
                </div>
              </div>
            </div>

            <!-- ══════════════════════════
                 TAB: Video
            ══════════════════════════ -->
            <div class="tab-content" *ngIf="activeTab === 'video' && project.video">
              <div class="video-wrap">
                <div class="video-thumb" (click)="watchVideo()">
                  <img [src]="project.images[0]" [alt]="project.title">
                  <div class="video-play-btn" [style.color]="project.color">
                    <i class="fa-regular fa-circle-play"></i>
                  </div>
                  <div class="video-duration">
                    <i class="fa-regular fa-clock"></i> 2:45
                  </div>
                </div>
              </div>
            </div>

            <!-- ══════════════════════════
                 TAB: How It Works
            ══════════════════════════ -->
            <div class="tab-content" *ngIf="activeTab === 'howItWorks'">
              <div class="hiw-section">

                <div class="hiw-header">
                  <h2>{{ 'PROJECTS.HOW_IT_WORKS' | translate }}</h2>
                  <p>{{ 'PROJECTS.HOW_SUBTITLE' | translate }}</p>
                </div>

                <div class="hiw-track">
                  <div class="hiw-line"></div>
                 <div class="hiw-line-fill"
  [style.background]="project.color" 
  [style.width]="getLineWidth()">
</div>

                 <div class="hiw-step"
     *ngFor="let step of project?.steps; let i = index" 
     [class.active]="activeStep === i"
     [class.done]="i < activeStep"
     (click)="goStep(i)">
                  <div class="hiw-circle"
  [style.border-color]="(activeStep === i || i < activeStep) ? '#77479b' : ''"
  [style.background]="(activeStep === i || i < activeStep) ? project.color : ''">
  
  <span *ngIf="i >= activeStep"
    [style.color]="activeStep === i ? 'white' : ''">
    {{ step.num }}
  </span>
  <i *ngIf="i < activeStep" class="fa-regular fa-check" style="color: white;"></i>
</div>
                    <div class="hiw-step-title"
                      [style.color]="activeStep === i ? project.color : ''">
                                {{ (translate.currentLang === 'ar' ? step.titleAr : step.titleEn) }}

                    </div>
                    <div class="hiw-step-desc">{{ (translate.currentLang === 'ar' ? step.descAr : step.descEn) }}</div>
                  </div>
                </div>

                <div class="hiw-detail" *ngIf="project.steps?.length && project.steps[activeStep]">
                  <div class="hiw-detail-num"
  [style.background]="project.color"
  style="color: white;">
  {{ project.steps[activeStep].num }}
</div>
                  <div class="hiw-detail-content">
                    <h4>{{ (translate.currentLang === 'ar' ? project.steps[activeStep].titleAr : project.steps[activeStep].titleEn) }}</h4>
                    <p>{{ (translate.currentLang === 'ar' ? project.steps[activeStep].detailDescAr : project.steps[activeStep].detailDescEn) }}</p>
                  </div>
                </div>

                <div class="hiw-dots">
                  <span class="hiw-dot"
                    *ngFor="let step of project.steps; let i = index"
                    [class.active]="activeStep === i"
                    [style.background]="activeStep === i ? project.color : ''"
                    [style.width]="activeStep === i ? '20px' : ''"
                    (click)="goStep(i)">
                  </span>
                </div>

              </div>
            </div>
            <!-- ══ END TAB: How It Works ══ -->

          </div>
          <!-- END pd-card -->
        </div>
        <!-- ── End Main Column ── -->

        <!-- ── Sidebar ── -->
        <aside class="pd-sidebar-col">

          <div class="pd-card pd-stats-card">
            <div class="card-head">
              <div class="card-head-icon"
                [style.background]="hexToRgba(project.color, 0.1)"
                [style.color]="project.color">
                <i class="fa-regular fa-chart-line"></i>
              </div>
              <h3>{{ 'PROJECTS.STATS' | translate }}</h3>
            </div>
            <div class="stat-item">
              <div class="stat-top">
                <span class="stat-label">
                  <i class="fa-regular fa-building"></i>
                  {{ 'PROJECTS.ORGANIZATIONS' | translate }}
                </span>
                <span class="stat-val" [style.color]="project.color">500+</span>
              </div>
              <div class="stat-track">
                <div class="stat-fill" [style.width]="'85%'" [style.background]="project.color"></div>
              </div>
            </div>
            <div class="stat-item">
              <div class="stat-top">
                <span class="stat-label">
                  <i class="fa-regular fa-face-smile"></i>
                  {{ 'PROJECTS.CUSTOMER_SATISFACTION' | translate }}
                </span>
                <span class="stat-val" [style.color]="project.color">95%</span>
              </div>
              <div class="stat-track">
                <div class="stat-fill" [style.width]="'95%'" [style.background]="project.color"></div>
              </div>
            </div>
            <div class="stat-item">
              <div class="stat-top">
                <span class="stat-label">
                  <i class="fa-regular fa-arrow-trend-up"></i>
                  {{ 'PROJECTS.EFFICIENCY_INCREASE' | translate }}
                </span>
                <span class="stat-val" [style.color]="project.color">30%+</span>
              </div>
              <div class="stat-track">
                <div class="stat-fill" [style.width]="'60%'" [style.background]="project.color"></div>
              </div>
            </div>
          </div>

        </aside>
        <!-- ── End Sidebar ── -->

      </div>
      <!-- ══════════════════════════
      SECTION: FAQ ACCORDION
══════════════════════════ -->
<!-- ══════════════════════════
      SECTION: FAQ ACCORDION
══════════════════════════ -->
  <div class="pd-card mt-3">

           <div class="card-head">
              <div class="card-head-icon"
                [style.background]="hexToRgba(project.color, 0.1)"
                [style.color]="project.color">
                <i class="fa-regular fa-circle-question"></i>

              </div>
              <h3>{{ 'PROJECTS.FAQ_TITLE' | translate }}</h3>
            </div>

        
          

<div class="faq-section py-2">
  <div class="container">
    <div class="row align-items-center">
      
      <!-- الجانب الأيمن: الأسئلة الشائعة -->
      <div class="col-lg-7 order-2 order-lg-1">
        <div class="faq-header mb-4">
          <p class="text-muted">{{ 'PROJECTS.FAQ_SUBTITLE' | translate }}</p>
        </div>

        <div class="accordion-container">
          <div class="accordion-item shadow-sm border-0 mb-3 rounded-4 overflow-hidden" 
               *ngFor="let faq of project.faqs; let i = index" [class.active]="faq.open">
            <div class="accordion-header d-flex justify-content-between align-items-center p-3 bg-white" 
                 (click)="toggleFaq(i)" style="cursor: pointer;">
              <span class="accordion-title fw-medium">
                {{ (translate.currentLang === 'ar' ? faq.questionAr : faq.questionEn) }}
              </span>
              <div class="accordion-icon-wrapper" [class.is-open]="faq.open">
                <div class="icon-circle">
                  <i class="fa-solid fa-chevron-down"></i>
                </div>
              </div>
            </div>

            <div class="accordion-content" [style.maxHeight]="faq.open ? '200px' : '0'" style="transition: all 0.4s ease;">
              <div class="content-inner p-3 bg-light text-secondary">
                {{ (translate.currentLang === 'ar' ? faq.answerAr : faq.answerEn) }}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- الجانب الأيسر: الصورة المتحركة -->
      <div class="col-lg-5 order-1 order-lg-2 mb-5 mb-lg-0">
        <div class="faq-visual-wrapper text-center">
          <!-- يمكنك استبدال المسار بصورة التقرير أو أي أيقونة 3D -->
          <div class="floating-image-container">
            <img src="../../../../../assets/images/projects/samem-qias.png" 
                 alt="Visual Support" 
                 class="img-fluid custom-tilt-shadow">
            
            <!-- إضافة عناصر ديكورية خلف الصورة (دوائر ملونة) -->
            <div class="blob-bg" [style.background]="project.color"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
</div>
    </div>
  </div>
  <!-- ===== END BODY ===== -->

</div>